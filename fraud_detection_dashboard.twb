      <aliases enabled='yes' />
      <column caption='Fraud_label' datatype='string' name='[Calculation_1897537536434176]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [isFraud] = 1 THEN &quot;Fraud&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Day' datatype='integer' name='[Calculation_1897537536651265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([step] / 24)' />
      </column>
      <column caption='Hour' datatype='integer' name='[Calculation_1897537536774146]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[step] % 24' />
      </column>
      <column caption='Amount category' datatype='string' name='[Calculation_1897537536856067]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [amount] &lt; 1000 THEN &quot;Low&quot;&#13;&#10;ELSEIF [amount] &lt; 10000 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
      </column>
      <column caption='no of records' datatype='integer' name='[Calculation_1897537550909445]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([isFraud])' />
      </column>
      <column caption='Fraud Transactions in TRANSFER &amp; CASH_OUT' datatype='integer' name='[Calculation_1897537552277511]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [isFraud]=1 AND &#13;&#10;([type]=&quot;TRANSFER&quot; OR [type]=&quot;CASH_OUT&quot;)&#13;&#10;THEN 1 END)' />
      </column>
      <column caption='Fraud Detection Rate' datatype='real' name='[Calculation_1897537552502792]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([isFlaggedFraud]) / SUM([isFraud])' />
      </column>
      <column caption='Fraud Amount' datatype='real' name='[Calculation_1897537552896009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [isFraud] = 1 THEN [amount] END)' />
      </column>
